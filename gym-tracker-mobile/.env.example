# Copier ce fichier vers .env.local puis remplir les valeurs.
# Après modification : redémarrer Metro avec `npx expo start -c`.
#
# ⚠️ Uniquement des variables EXPO_PUBLIC_* ici — elles sont embarquées
# dans le bundle JS. JAMAIS de clé secrète (service_role, etc.).

# Supabase — OPTIONNEL (sans ces valeurs l'app tourne 100 % offline)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
