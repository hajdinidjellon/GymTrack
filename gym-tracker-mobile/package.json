{
  "name": "gym-tracker-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "node --max-old-space-size=4096 ./node_modules/.bin/expo start",
    "android": "node --max-old-space-size=4096 ./node_modules/.bin/expo start --android",
    "ios": "node --max-old-space-size=4096 ./node_modules/.bin/expo start --ios",
    "web": "expo start --web",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/rajdhani": "^0.4.1",
    "@expo/metro": "^55.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@shopify/react-native-skia": "2.2.12",
    "@supabase/supabase-js": "^2.105.4",
    "aes-js": "^3.1.2",
    "date-fns": "^3.6.0",
    "expo": "54.0.34",
    "expo-audio": "~1.1.1",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "moti": "^0.30.0",
    "nativewind": "^4.2.3",
    "phosphor-react-native": "^3.0.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/aes-js": "^3.1.4",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}
